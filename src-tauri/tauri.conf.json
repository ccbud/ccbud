{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ccbud",
  "version": "1.2.1",
  "identifier": "dev.ccbud.gateway",
  "build": {
    "frontendDist": "../src/renderer",
    "beforeDevCommand": "npm run build:css && npm run sync:shared",
    "beforeBuildCommand": "npm run build:css && npm run sync:shared"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ccbud",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "popover",
        "url": "popover.html",
        "title": "ccbud usage",
        "width": 424,
        "height": 344,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ccbud/ccbud/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCMTMwRjI5MDhCNjE1NzUKUldSMUZiWUlLUThUK3kybFBUU3ljMWUyenAwR3U1NjdPZm1jM25ocndIclhLYUFGTU92KzJXRFQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
