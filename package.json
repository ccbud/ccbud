{
  "name": "ccbud",
  "version": "1.2.5",
  "description": "ccbud — Coding CLI Buddy. A cross-platform desktop app that proxies Claude Code to any Anthropic-compatible provider (one-click switching, model mapping) and browses your Claude Code & Codex session history.",
  "author": {
    "name": "loadchange",
    "email": "soocto@gmail.com"
  },
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccbud/ccbud.git"
  },
  "scripts": {
    "build:css": "tailwindcss -i src/renderer/input.css -o src/renderer/styles.css",
    "sync:shared": "node -e \"require('fs').cpSync('src/shared','src/renderer/shared',{recursive:true})\"",
    "sync:clarity": "node -e \"const fs=require('fs');fs.mkdirSync('src/renderer/vendor/clarity/src',{recursive:true});fs.copyFileSync('node_modules/@microsoft/clarity/index.js','src/renderer/vendor/clarity/index.js');fs.copyFileSync('node_modules/@microsoft/clarity/src/utils.js','src/renderer/vendor/clarity/src/utils.js')\"",
    "tauri": "tauri",
    "release": "node scripts/release.js",
    "start": "tauri dev",
    "dev": "tauri dev",
    "test": "node test/selftest.js",
    "update:cask": "node scripts/update-cask.js",
    "dist": "tauri build",
    "dist:mac": "tauri build",
    "dist:win": "tauri build",
    "dist:linux": "tauri build"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@tailwindcss/cli": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "marked": "^18.0.5",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "js-tiktoken": "^1.0.21"
  }
}
