{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CCBuddy",
  "version": "1.3.5",
  "identifier": "dev.ccbud.gateway",
  "build": {
    "frontendDist": "../src/renderer",
    "beforeDevCommand": "npm run build:css && npm run sync:shared && npm run sync:clarity",
    "beforeBuildCommand": "npm run build:css && npm run sync:shared && npm run sync:clarity"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CC Buddy",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "popover",
        "url": "popover.html",
        "title": "CC Buddy Usage",
        "width": 424,
        "height": 344,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://*.clarity.ms https://c.bing.com; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' https://www.clarity.ms https://*.clarity.ms"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ccbud/ccbud/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCMTMwRjI5MDhCNjE1NzUKUldSMUZiWUlLUThUK3kybFBUU3ljMWUyenAwR3U1NjdPZm1jM25ocndIclhLYUFGTU92KzJXRFQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "upgradeCode": "3607f9f8-3416-53dd-8ba7-5c1d6a348351"
      }
    },
    "macOS": {
      "bundleName": "CC Buddy"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
