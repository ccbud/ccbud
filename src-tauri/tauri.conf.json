{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ccbud",
  "version": "1.0.18",
  "identifier": "dev.ccbud.gateway",
  "build": {
    "frontendDist": "../src/renderer",
    "beforeDevCommand": "npm run build:css && npm run sync:shared",
    "beforeBuildCommand": "npm run build:css && npm run sync:shared"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ccbud",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
